
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the Setu Guardian application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The primary phone number of the user."
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user account was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "phoneNumber",
        "createdAt",
        "updatedAt"
      ]
    },
    "PublicProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PublicProfile",
      "type": "object",
      "description": "A searchable subset of user data available to all authenticated users.",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["userId", "displayName", "email"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "A single chat message between two connected users.",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "timestamp"]
    },
    "TrustedContact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrustedContact",
      "type": "object",
      "description": "Represents a trusted emergency contact designated by a User.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "contactName": { "type": "string" },
        "contactPhoneNumber": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "relationshipToUser": { "type": "string" },
        "isAppUser": { "type": "boolean" },
        "appUserId": { "type": "string" }
      },
      "required": ["id", "userId", "contactName", "contactPhoneNumber", "isAppUser"]
    },
    "Journey": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Journey",
      "type": "object",
      "description": "Represents a specific journey initiated by a user for live tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "journeyType": { "type": "string" },
        "status": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "startLocationDescription": { "type": "string" },
        "endLocationDescription": { "type": "string" },
        "sharedWithContactIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "journeyType", "status", "startTime", "startLocationDescription", "endLocationDescription", "sharedWithContactIds"]
    },
    "SupportRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SupportRequest",
      "type": "object",
      "description": "Represents connection requests, safety check-ins, or help requests.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "requestType": { "type": "string", "enum": ["ConnectionRequest", "JourneyNotification", "NeedARide", "MeetingCompanion"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Accepted", "Declined", "Read"] },
        "senderName": { "type": "string" },
        "senderId": { "type": "string" }
      },
      "required": ["id", "userId", "requestType", "description", "timestamp", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/publicProfiles/{userId}",
        "definition": {
          "entityName": "PublicProfile",
          "schema": { "$ref": "#/backend/entities/PublicProfile" },
          "description": "Searchable user profiles."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Private user profiles."
        }
      },
      {
        "path": "/users/{userId}/trustedContacts/{contactId}",
        "definition": {
          "entityName": "TrustedContact",
          "schema": { "$ref": "#/backend/entities/TrustedContact" },
          "description": "User's trusted circle."
        }
      },
      {
        "path": "/users/{userId}/chats/{friendId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Direct messages between friends."
        }
      },
      {
        "path": "/users/{userId}/supportRequests/{requestId}",
        "definition": {
          "entityName": "SupportRequest",
          "schema": { "$ref": "#/backend/entities/SupportRequest" },
          "description": "Notifications and requests."
        }
      }
    ]
  }
}
